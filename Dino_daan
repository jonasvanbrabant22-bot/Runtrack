<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Dino Avontuur</title>
    <style>
        * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
        body { margin: 0; padding: 0; background-color: #0a2f10; font-family: 'Segoe UI', sans-serif; display: flex; justify-content: center; align-items: center; height: 100vh; overflow: hidden; }
        #app-container { width: 100%; max-width: 500px; height: 100vh; background: #222; position: relative; border: 4px solid #5d4037; overflow: hidden; }
        .full-bg { position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; z-index: 1; }
        
        .overlay-onder { 
            position: absolute; bottom: 0; left: 0; width: 100%; 
            background: rgba(255, 255, 255, 0.95); padding: 15px; z-index: 10; 
            border-top: 6px solid #5d4037; text-align: center; 
            min-height: 260px; display: flex; flex-direction: column; justify-content: center; 
        }

        .verhaal-tekst { font-size: 21px; line-height: 1.4; color: #1b5e20; font-weight: bold; margin-bottom: 10px; }
        .verhaal-tekst span { display: block; margin-bottom: 4px; }

        .btn-actie { background: #4caf50; color: white; border: none; padding: 15px; width: 100%; font-size: 20px; border-radius: 50px; cursor: pointer; box-shadow: 0 5px #2e7d32; font-weight: bold; margin-top: 8px; }
        .btn-actie:active { transform: translateY(3px); box-shadow: none; }

        .btn-speak { 
            background: #2196F3; color: white; border: none; 
            width: 55px; height: 55px; border-radius: 50%; font-size: 26px; 
            cursor: pointer; margin: 0 auto 10px auto; display: block; 
            box-shadow: 0 4px #1976D2; border: 2px solid white;
        }

        .reken-box { background: #5d4037; color: white; padding: 10px; border-radius: 15px; margin-bottom: 10px; }
        .getal-cirkel { background: white; color: #333; width: 45px; height: 45px; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; font-size: 22px; margin: 3px; font-weight: bold; border: 3px solid #333; }
        .btn-keuze { background: #ff9800; color: white; border: none; width: 70px; height: 70px; font-size: 32px; border-radius: 15px; margin: 5px; cursor: pointer; box-shadow: 0 4px #e65100; }

        #menu { position: absolute; inset: 0; z-index: 100; background: #fefcf0; display: flex; flex-direction: column; align-items: center; justify-content: flex-start; padding: 20px; overflow-y: auto; }
        .hidden { display: none !important; }
    </style>
</head>
<body>

<div id="app-container">
    <div id="menu">
        <h1 style="color: #1b5e20; font-size: 32px; margin-bottom: 10px;">Dino Avontuur</h1>
        <img src="homefoto.jpeg" style="width: 80%; border-radius: 15px; margin-bottom: 15px; border: 3px solid #5d4037;">
        <button class="btn-actie" onclick="start(1)">1. De Vlinder</button>
        <button class="btn-actie" onclick="start(2)">2. De Tas & Bril</button>
        <button class="btn-actie" onclick="start(3)">3. De Kristalgrot</button>
        <button class="btn-actie" onclick="start(4)">4. De Hoge Berg</button>
        <button class="btn-actie" onclick="start(5)">5. Het Dino Feest</button>
    </div>

    <div id="spel" class="hidden">
        <img id="bg-foto" src="" class="full-bg">
        <div id="tekst-container" class="overlay-onder">
            <button class="btn-speak" id="speak-btn" onclick="spreekTekst()">🔊</button>
            <div id="tekst-veld" class="verhaal-tekst"></div>
            
            <div id="reken-veld" class="hidden">
                <div class="reken-box">
                    <div class="getal-cirkel" id="som-top">?</div><br>
                    <div class="getal-cirkel" id="som-links">?</div>
                    <div class="getal-cirkel" style="background:#fff9c4; border: 3px dashed #333;">?</div>
                </div>
                <div id="knoppen-veld"></div>
            </div>

            <div id="keuze-veld" class="hidden">
                <button id="btn-volgend-hoofdstuk" class="btn-actie" onclick="">JA! Verder spelen</button>
                <button class="btn-actie" onclick="location.reload()" style="background:#d32f2f; margin-top:10px;">NEE, naar menu</button>
            </div>

            <button id="btn-volgende" class="btn-actie" onclick="verder()">Verder</button>
        </div>
    </div>
</div>

<script>
    const verhalen = {
        1: [
            { img: "1.1.jpeg", z: ["Dit is Daan de dino.", "Daan speelt in het bos.", "Hij is erg blij."] },
            { img: "1.2.jpeg", z: ["Kijk! Een vlinder.", "De vlinder is blauw.", "Daan loopt er achter aan."] },
            { img: "1.3.jpeg", z: ["Oei, Daan is ver gelopen.", "Hij is nu verdwaald.", "Wil jij Daan helpen?"] },
            { img: "1.4.jpeg", z: ["Kijk daar! Een diepe kuil.", "De brug over de kuil is kapot.", "Daan kan niet naar huis."] },
            { type: "math", imgs: ["1.5.jpeg", "1.6.jpeg", "1.7.jpeg"], z: ["Maak de brug weer heel.", "Los de sommen op."], endImg: "1.8.jpeg", nextH: 2 }
        ],
        2: [
            { img: "2.1.jpeg", z: ["Daan ziet een tas.", "De tas ligt in het gras.", "Wat zou er in zitten?"] },
            { img: "2.2.jpeg", z: ["De tas zit stevig op slot.", "Daan krijgt hem niet open.", "Help jij de code te kraken?"] },
            { type: "math", imgs: ["2.3.jpeg", "2.4.jpeg", "2.5.jpeg", "2.6.jpeg", "2.7.jpeg", "2.8.jpeg"], z: ["Reken goed uit.", "Dan gaat de tas open.", "Kraak de code!"], endImg: "2.9.jpeg", nextH: 0 },
            { img: "3.1.jpeg", z: ["De tas gaat open!", "Daan kijkt naar binnen.", "Er ligt een zwarte zonnebril!"] },
            { img: "3.2.jpeg", z: ["Daan zet de bril op.", "Hij ziet er stoer uit.", "Nu is hij een coole dino!"] },
            { img: "3.3.jpeg", z: ["Kijk Daan nu eens!", "Met zijn zwarte bril.", "Daan is super blij!"], isEnd: true, nextH: 3 }
        ],
        3: [
            { img: "4.1.jpeg", z: ["Daan komt bij een grot.", "Het is er erg donker.", "Daan ziet bijna niets."] },
            { img: "4.2.jpeg", z: ["Er liggen glimmende stenen.", "Als we die verzamelen...", "...dan maken ze licht!"] },
            { type: "math", imgs: ["4.3.jpeg", "4.4.jpeg", "4.5.jpeg", "4.6.jpeg"], z: ["Verzamel de kristallen.", "Maak de sommen.", "Maak de grot licht!"], endImg: "4.7.jpeg", nextH: 4 }
        ],
        4: [
            { img: "5.1.jpeg", z: ["Daan staat bij een berg.", "De berg is heel hoog.", "Daan wil naar de top."] },
            { img: "5.2.jpeg", z: ["Met zijn zwarte bril op...", "...ziet hij de weg goed.", "Klim je met hem mee?"] },
            { type: "math", imgs: ["5.3.jpeg", "5.4.jpeg", "5.5.jpeg", "5.6.jpeg"], z: ["Bouw de traptreden.", "Reken de sommen uit.", "Naar de top!"], endImg: "5.7.jpeg", nextH: 5 }
        ],
        5: [
            { img: "6.1.jpeg", z: ["Daan is boven!", "Hij ziet al zijn vriendjes.", "Ze houden een groot feest."] },
            { img: "6.2.jpeg", z: ["Daan danst en lacht.", "Iedereen vindt zijn bril cool.", "Wat een mooi avontuur."] },
            { img: "6.3.jpeg", z: ["Daan is nu weer thuis.", "Samen met al zijn vrienden.", "Dankjewel voor het helpen!"], isEnd: true, nextH: 1 }
        ]
    };

    let lijst = [];
    let stap = 0;
    let score = 0;
    let antwoord = 0;

    function spreekTekst() {
        window.speechSynthesis.cancel();
        let zinnen = lijst[stap].z.join(". ");
        let msg = new SpeechSynthesisUtterance(zinnen);
        msg.lang = 'nl-BE';
        msg.pitch = 1.1;
        msg.rate = 0.85;

        let voices = window.speechSynthesis.getVoices();
        let besteStem = voices.find(v => v.lang.includes('nl-BE') && v.name.includes('Enhanced')) || 
                        voices.find(v => v.lang.includes('nl-BE')) ||
                        voices[0];
        if (besteStem) msg.voice = besteStem;

        window.speechSynthesis.speak(msg);
        const btn = document.getElementById('speak-btn');
        btn.style.background = '#4caf50';
        msg.onend = () => { btn.style.background = '#2196F3'; };
    }

    function start(nr) {
        lijst = verhalen[nr];
        stap = 0; score = 0;
        document.getElementById('menu').classList.add('hidden');
        document.getElementById('spel').classList.remove('hidden');
        document.getElementById('keuze-veld').classList.add('hidden');
        document.getElementById('btn-volgende').classList.remove('hidden');
        toon();
    }

    function toon() {
        let item = lijst[stap];
        document.getElementById('bg-foto').src = item.img || item.imgs[0];
        document.getElementById('tekst-veld').innerHTML = item.z.map(z => `<span>${z}</span>`).join('');

        if(item.type === "math") {
            document.getElementById('btn-volgende').classList.add('hidden');
            document.getElementById('reken-veld').classList.remove('hidden');
            maakSom();
        } else {
            document.getElementById('btn-volgende').classList.remove('hidden');
            document.getElementById('reken-veld').classList.add('hidden');
        }
    }

    function verder() {
        window.speechSynthesis.cancel();
        let item = lijst[stap];
        
        if(item.isEnd) {
            document.getElementById('keuze-veld').classList.remove('hidden');
            document.getElementById('btn-volgende').classList.add('hidden');
            document.getElementById('btn-volgend-hoofdstuk').onclick = () => {
                if(item.nextH === 1) location.reload(); // Einde spel
                else start(item.nextH);
            };
            return;
        }

        stap++;
        if(stap < lijst.length) {
            toon();
        } else {
            location.reload();
        }
    }

    function maakSom() {
        let item = lijst[stap];
        document.getElementById('bg-foto').src = item.imgs[score];
        let t = Math.floor(Math.random() * 6) + 4;
        let l = Math.floor(Math.random() * (t + 1));
        antwoord = t - l;
        document.getElementById('som-top').innerText = t;
        document.getElementById('som-links').innerText = l;
        
        let veld = document.getElementById('knoppen-veld');
        veld.innerHTML = "";
        let opties = [antwoord];
        while(opties.length < 3) {
            let f = Math.floor(Math.random() * 11);
            if(!opties.includes(f)) opties.push(f);
        }
        opties.sort((a,b) => a-b);
        opties.forEach(o => {
            veld.innerHTML += `<button class="btn-keuze" onclick="check(${o})">${o}</button>`;
        });
    }

    function check(g) {
        let item = lijst[stap];
        if(g === antwoord) {
            score++;
            if(score >= item.imgs.length) {
                document.getElementById('bg-foto').src = item.endImg;
                document.getElementById('reken-veld').classList.add('hidden');
                
                if(item.nextH === 0) {
                    document.getElementById('btn-volgende').classList.remove('hidden');
                    document.getElementById('tekst-veld').innerHTML = "<span>GOED ZO!</span><span>De tas gaat nu open...</span>";
                } else {
                    document.getElementById('tekst-veld').innerHTML = "<span>GEWELDIG!</span><span>Je hebt het opgelost!</span><span>Gaan we naar het volgende avontuur?</span>";
                    document.getElementById('keuze-veld').classList.remove('hidden');
                    document.getElementById('btn-volgend-hoofdstuk').onclick = () => start(item.nextH);
                }
            } else {
                maakSom();
            }
        } else {
            let txt = document.getElementById('tekst-veld');
            txt.innerHTML = "<span style='color:red;'>Oei, probeer het nog eens!</span>";
            setTimeout(() => toon(), 800);
        }
    }

    window.speechSynthesis.onvoiceschanged = () => { window.speechSynthesis.getVoices(); };
</script>
</body>
</html>
